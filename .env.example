# Copy to .env.local for local development (never commit .env.local)
VITE_GOOGLE_CLIENT_ID=
# Optional: pre-fill a default spreadsheet for your own local testing.
# Everyone else can paste their own Sheet URL after signing in.
# VITE_SHEET_ID=

# Optional: Apps Script Web App URL → empty commit on GitHub when you add an app.
# Never puts application data in the repo. See google-apps-script/onEdit.gs
# VITE_GITHUB_PING_URL=
# VITE_GITHUB_PING_SECRET=
